# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Optional: override DEFAULT_CONFIG without editing code.
# Any AXONAI_* variable below, when set, replaces the matching key
# in axonai/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
#AXONAI_LLM_PROVIDER=openai
#AXONAI_DEEP_THINK_LLM=gpt-5.4
#AXONAI_QUICK_THINK_LLM=gpt-5.4-mini
#AXONAI_LLM_BACKEND_URL=
#AXONAI_OUTPUT_LANGUAGE=English
#AXONAI_MAX_DEBATE_ROUNDS=1
#AXONAI_MAX_RISK_ROUNDS=1
#AXONAI_CHECKPOINT_ENABLED=false
